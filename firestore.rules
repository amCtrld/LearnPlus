rules_version = '2';

/**
 * Firestore Security Rules for LearnPlus Research Platform
 * 
 * Security Model:
 * - Anonymous authentication used for participants
 * - Access codes gate entry to study
 * - Session-based access control
 * - Admin operations via Firebase Admin SDK (server-side)
 * 
 * Collections:
 * - accessCodes: One-time codes for study access
 * - userSessions: Tracks participant sessions
 * - stepLogs: Records problem-solving interactions
 * - surveys: Post-study feedback
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Access Codes Collection
    // - Read: Only server-side via Admin SDK
    // - Write: Only server-side via Admin SDK
    // - No client-side access (prevents code enumeration)
    match /accessCodes/{codeId} {
      allow read: if false;
      allow write: if false;
    }
    
    // User Sessions Collection
    // - Read: Owner can read their own session
    // - Create: Authenticated users can create their session
    // - Update: Owner can update their session
    // - Delete: Not allowed (research data integrity)
    match /userSessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'studyMode', 'startTime']);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId; // Prevent userId changes
      allow delete: if false; // Preserve research data
    }
    
    // Step Logs Collection (Problem-solving interactions)
    // - Read: Owner can read their logs
    // - Create: Authenticated users can log their actions
    // - Update: Owner can update their logs (for corrections)
    // - Delete: Not allowed (research data integrity)
    match /stepLogs/{logId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'problemId', 'stepNumber', 'timestamp']);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId; // Prevent userId changes
      allow delete: if false; // Preserve research data
    }
    
    // Surveys Collection
    // - Read: Owner can read their survey
    // - Create: Authenticated users can submit once
    // - Update: Not allowed (prevent survey tampering)
    // - Delete: Not allowed (research data integrity)
    match /surveys/{surveyId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'studyMode', 'timestamp'])
                    && !exists(/databases/$(database)/documents/surveys/$(request.auth.uid)); // One survey per user
      allow update: if false; // Immutable after submission
      allow delete: if false; // Preserve research data
    }
    
    // AI Chat Logs Collection (Optional - for storing chat history)
    // - Read: Owner can read their chat logs
    // - Create: Authenticated users can log chats
    // - Update: Not allowed
    // - Delete: Not allowed (research data integrity)
    match /chatLogs/{chatId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.keys().hasAll(['userId', 'problemId', 'timestamp']);
      allow update: if false;
      allow delete: if false;
    }
    
    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
